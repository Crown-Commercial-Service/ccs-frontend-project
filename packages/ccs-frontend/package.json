{
  "name": "ccs-frontend",
  "description": "CCS Frontend contains assets and components used in CCS projects",
  "version": "2.2.0",
  "main": "dist/ccs/all.bundle.js",
  "types": "dist/ccs/@types/all.d.ts",
  "module": "dist/ccs/all.mjs",
  "sass": "dist/ccs/all.scss",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "sass": "./dist/ccs/all.scss",
      "import": "./dist/ccs/all.mjs",
      "types": "./dist/ccs/@types/all.d.ts",
      "require": "./dist/ccs/all.bundle.js",
      "default": "./dist/ccs/all.bundle.js"
    },
    "./*": "./*",
    "./dist/": "./dist/",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">= 4.2.0"
  },
  "author": {
    "name": "Crown Commercial Service"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Crown-Commercial-Service/ccs-frontend-project.git"
  },
  "bugs": {
    "url": "https://github.com/Crown-Commercial-Service/ccs-frontend-project"
  },
  "homepage": "https://github.com/Crown-Commercial-Service/ccs-frontend-project#readme",
  "keywords": [
    "crown commercial service",
    "ccs",
    "frontend",
    "design system",
    "template"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "gulp dev --color",
    "prebuild:package": "npm run clean:package",
    "prebuild:release": "npm run clean:release",
    "build": "npm run build:package",
    "build:package": "gulp build:package --color",
    "build:release": "gulp build:release --color",
    "build:types": "tsc",
    "clean": "npm run clean:package",
    "clean:package": "del-cli dist",
    "clean:release": "del-cli ../../dist --force",
    "clean:tmp": "del-cli dist/tmp",
    "version": "echo $npm_package_version"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@ccs-frontend/config": "*",
    "@ccs-frontend/lib": "*",
    "@ccs-frontend/tasks": "*",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jquery": "^3.5.33",
    "autoprefixer": "^10.4.22",
    "cssnano": "^7.1.2",
    "cssnano-preset-default": "^7.0.1",
    "del-cli": "^7.0.0",
    "gulp": "^5.0.1",
    "gulp-replace": "^1.1.4",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "puppeteer": "^23.11.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "govuk-frontend": "^5.13.0",
    "jquery": "^3.x"
  }
}
