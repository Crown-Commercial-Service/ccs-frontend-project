{
  "private": true,
  "name": "@ccs-frontend/repository",
  "description": "Used only for the development of CCS Frontend, see `packages/ccs-frontend/package.json` for the published `package.json`",
  "engines": {
    "node": "^22.11.0",
    "npm": "^11.1.0"
  },
  "license": "MIT",
  "workspaces": [
    "packages/ccs-frontend",
    "packages/ccs-frontend-review",
    "shared/*"
  ],
  "scripts": {
    "postinstall": "npm ls --depth=0",
    "start": "npm run dev",
    "build-release": "./bin/build-release.sh",
    "publish-release": "./bin/publish-release.sh",
    "publish-preview": "./bin/publish-preview.sh",
    "dev": "concurrently \"npm run dev --workspace @ccs-frontend/review\" \"npm run dev --workspace ccs-frontend\" --kill-others --names \"app,pkg\" --prefix-colors \"red.dim,blue.dim\"",
    "predev": "npm run build -- --ignore-scripts",
    "build": "npm run build --workspace ccs-frontend --workspace @ccs-frontend/review",
    "build:package": "cross-env-shell NODE_ENV=production npm run build:package --workspace ccs-frontend",
    "build:release": "cross-env-shell NODE_ENV=production npm run build:release --workspace ccs-frontend",
    "postbuild:package": "jest --color --selectProjects \"Build tasks\" --testMatch \"**/build/package.unit.test.mjs\"",
    "postbuild:release": "jest --color --selectProjects \"Build tasks\" --testMatch \"**/build/release.unit.test.mjs\"",
    "clean": "npm run clean --workspaces --if-present",
    "pretest": "npm run build",
    "test": "jest --color --ignoreProjects \"Build tasks\" --maxWorkers=50%",
    "lint": "npm run lint:js && npm run lint:ts && npm run lint:scss",
    "lint:fix": "npm run lint:js:fix && npm run lint:ts:fix && npm run lint:scss:fix",
    "lint:js": "npm run lint:js:cli -- \"**/*.{cjs,js,md,mjs}\"",
    "lint:js:fix": "npm run lint:js:cli -- --fix \"**/*.{cjs,js,md,mjs}\"",
    "lint:js:cli": "eslint --cache --cache-location .cache/eslint --cache-strategy content --color --max-warnings 0",
    "lint:ts": "npm run lint:ts:cli -- \"**/*.ts\"",
    "lint:ts:fix": "npm run lint:ts:cli -- --fix \"**/*.ts\"",
    "lint:ts:cli": "eslint --config eslint.typescript.config.mjs --cache --cache-location .cache/tslint --cache-strategy content --color --max-warnings 0",
    "lint:scss": "npm run lint:scss:cli -- \"**/*.{md,scss}\"",
    "lint:scss:fix": "npm run lint:scss:cli -- --fix --allow-empty-input \"**/*.{md,scss}\"",
    "lint:scss:cli": "stylelint --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore --max-warnings 0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@ccs-frontend/config": "*",
    "@ccs-frontend/helpers": "*",
    "@ccs-frontend/lib": "*",
    "@ccs-frontend/tasks": "*",
    "@eslint/js": "^9.28.0",
    "@stylistic/eslint-plugin-js": "^3.1.0",
    "@stylistic/eslint-plugin-ts": "^3.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^28.12.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-node-single-context": "^29.4.0",
    "jest-puppeteer": "^11.0.0",
    "jest-regex-util": "^29.4.3",
    "jest-serializer-html": "^7.1.0",
    "postcss-markdown": "^1.3.0",
    "stylelint": "^16.20.0",
    "stylelint-config-gds": "^2.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "optionalDependencies": {
    "puppeteer": "^23.11.1"
  }
}
